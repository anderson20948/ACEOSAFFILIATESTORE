  function getBotResponse(input) {
    const q = input.toLowerCase().trim();
    for (const item of ACEOS_KB) {
      if (item.keys.some(k => q.includes(k))) {
        return item.ans;
      }
    }
    return `🤔 Good question! For "${input}", I recommend:\n• Check the relevant dashboard section (Commerce, Signal, Advertising)\n• Review the docs at /docs\n• Contact our support team for personalized help\n\nYou can also ask me about: affiliate tips, earning strategies, ad optimization, or any platform feature!`;
  }

  function appendMsg(text, role) {
    const box = document.getElementById('chatbot-messages');
    const div = document.createElement('div');
    div.className = `chat-msg ${role}`;
    // Convert **bold** markdown and line breaks
    div.innerHTML = `<span>${text.replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>').replace(/\n/g,'<br>')}</span>`;
    box.appendChild(div);
    box.scrollTop = box.scrollHeight;
    return div;
  }

  function showTyping() {
    const box = document.getElementById('chatbot-messages');
    const div = document.createElement('div');
    div.className = 'chat-msg bot typing';
    div.id = 'typing-indicator';
    div.innerHTML = '<span></span><span></span><span></span>';
    box.appendChild(div);
    box.scrollTop = box.scrollHeight;
  }

  function removeTyping() {
    const t = document.getElementById('typing-indicator');
    if (t) t.remove();
  }

  function sendChatMessage() {
    const input = document.getElementById('chatbot-input');
    const text = (input.value || '').trim();
    if (!text) return;
    input.value = '';
    // Hide suggestions after first message
    document.getElementById('chatbot-suggestions').style.display = 'none';
    appendMsg(text, 'user');
    showTyping();
    setTimeout(() => {
      removeTyping();
      appendMsg(getBotResponse(text), 'bot');
    }, 700 + Math.random() * 400);
  }

  function sendSuggest(el) {
    document.getElementById('chatbot-input').value = el.textContent;
    sendChatMessage();
  }
  </script>

